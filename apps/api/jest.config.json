{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "roots": ["<rootDir>/src"],
  "testMatch": ["**/__tests__/**/*.ts", "**/*.test.ts"],
  "transform": {
    "^.+\\.ts$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@pharmtrace/shared/(.*)$": "<rootDir>/../../packages/shared/$1"
  },
  "collectCoverageFrom": ["src/**/*.ts", "!src/**/*.d.ts"]
}
